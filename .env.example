# Copie para .env.local e preencha quando tiver os valores.

# ID do container do Google Tag Manager (ex.: GTM-XXXXXXX).
# Sem este valor, o GTM simplesmente não carrega (o rastreamento de cliques
# por data-label continua empurrando eventos para o dataLayer, prontos para
# quando o GTM existir).
NEXT_PUBLIC_GTM_ID=

# URL de produção do link na bio (para metadata/OG, sitemap e robots).
# Padrão de fallback: https://linkbio-movelart.vercel.app
NEXT_PUBLIC_SITE_URL=
